{
  "rules": [
    {
      "root": "server",
      "extensions": [".js"],
      "maxLines": 360
    },
    {
      "root": "frontend/src",
      "extensions": [".ts"],
      "maxLines": 360
    },
    {
      "root": "frontend/src",
      "extensions": [".vue"],
      "maxLines": 380
    },
    {
      "root": "frontend/src",
      "extensions": [".html"],
      "maxLines": 700
    },
    {
      "root": "frontend/src",
      "extensions": [".css"],
      "maxLines": 420
    },
    {
      "root": "frontend/test",
      "extensions": [".ts"],
      "maxLines": 360
    },
    {
      "root": "scripts",
      "extensions": [".js"],
      "maxLines": 360
    },
    {
      "root": "tests",
      "extensions": [".js"],
      "maxLines": 880
    }
  ],
  "overrides": {
    "frontend/src/features/library/useLibraryAdminState.ts": 420,
    "frontend/src/features/admin/taxonomy/useTaxonomyAdmin.ts": 330,
    "frontend/src/views/CatalogView.vue": 340,
    "scripts/update_geogebra_bundle.js": 480
  }
}
