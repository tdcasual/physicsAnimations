{
  "name": "physics-animations-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --import ./test/node-localstorage-shim.mjs ./node_modules/vitest/vitest.mjs",
    "test:unit": "node --import ./test/node-localstorage-shim.mjs ./node_modules/vitest/vitest.mjs",
    "test:unit:coverage": "node --import ./test/node-localstorage-shim.mjs ./node_modules/vitest/vitest.mjs --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^28.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "rollup": "^4.59.0"
  }
}
