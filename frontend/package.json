{
  "name": "physics-animations-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --import ./test/node-localstorage-shim.mjs ./node_modules/vitest/vitest.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src --ext .ts,.tsx,.vue --fix",
    "guard:css": "node scripts/guardCssEngineering.js",
    "guard:admin": "node scripts/guardAdminContrast.js",
    "audit:contrast": "node scripts/contrastAudit.mjs",
    "analyze": "npm run build && npx tsx scripts/bundle-analyze.ts",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint-plugin-import-x": "^4.16.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.11.3",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
